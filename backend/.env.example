# AI 问数 SSO 配置
SSO_CLIENT_ID=your_sso_client_id
SSO_PLATFORM_URL=https://sso.example.com
SSO_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----"
# 使用字面量 \\n 即可，服务启动时会还原为 PEM 换行；启用 SSO 时必须配置完整公钥。

# 外部 HR 人员搜索服务。未配置时接口明确返回 503，不使用隐藏内网默认地址。
HR_API_URL=http://hr.example.com:8500
